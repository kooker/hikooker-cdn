{% if tags_list.first[0] == null %}

	{% for tag in tags_list %} 
	<a class="item-node" href="{{ BASE_PATH }}{{ site.JB.tags_path }}#{{ tag }}-ref">{{ tag }}<sup>{{ site.tags[tag].size }}</sup></a>
    {% endfor %}

{% else %}
    
	{% for tag in tags_list %} 
	<a class="item-node" href="{{ BASE_PATH }}{{ site.JB.tags_path }}#{{ tag[0] }}-ref">{{ tag[0] }}<sup>{{ tag[1].size }}</sup></a>
    {% endfor %}

{% endif %}

{% assign tags_list = nil %}